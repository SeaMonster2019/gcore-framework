{
    "$schema": "./@types/schema/package/index.json",
    "package_version": 2,
    "name": "gcore-framework",
    "version": "1.0.0",
    "author": "SeaMonster1919",
    "editor": ">=3.8.7",
    "scripts": {
        "preinstall": "node ./scripts/preinstall.js",
        "build": "npx tsc",
        "build:idx": "npx barrelsby --directory ./assets/scripts --mode top --delete"
    },
    "description": "i18n:gcore-framework.description",
    "main": "./dist/main.js",
    "exports": {
        "./event": {
            "types": "./assets/scripts/event/index.ts",
            "default": "./assets/scripts/event/index.ts"
        },
        "./storage": {
            "types": "./assets/scripts/storage/index.ts",
            "default": "./assets/scripts/storage/index.ts"
        },
        "./utils": {
            "types": "./assets/scripts/utils/index.ts",
            "default": "./assets/scripts/utils/index.ts"
        },
        "./res": {
            "types": "./assets/scripts/res/index.ts",
            "default": "./assets/scripts/res/index.ts"
        },
        "./mvc": {
            "types": "./assets/scripts/mvc/index.ts",
            "default": "./assets/scripts/mvc/index.ts"
        },
        "./ui": {
            "types": "./assets/scripts/ui/index.ts",
            "default": "./assets/scripts/ui/index.ts"
        },
        "./i18n": {
            "types": "./assets/scripts/i18n/index.ts",
            "default": "./assets/scripts/i18n/index.ts"
        },
        "./fsm": {
            "types": "./assets/scripts/fsm/index.ts",
            "default": "./assets/scripts/fsm/index.ts"
        },
        "./core-init": {
            "types": "./assets/scripts/core-init.ts",
            "default": "./assets/scripts/core-init.ts"
        }
    },
    "dependencies": {
        "@msgpack/msgpack": "^3.1.3",
        "papaparse": "^5.4.1",
        "xlsx": "^0.18.5",
        "fs-extra": "^10.0.0",
        "long": "^5.3.2",
        "vue": "^3.1.4"
    },
    "devDependencies": {
        "@cocos/creator-types": "^3.8.7",
        "@types/fs-extra": "^9.0.5",
        "@types/node": "^18.17.1",
        "ctix": "^2.8.0",
        "typescript": "^5.8.2"
    },
    "panels": {
        "default": {
            "title": "gcore框架工具",
            "type": "dockable",
            "main": "dist/panels/default",
            "size": {
                "min-width": 400,
                "min-height": 300,
                "width": 1024,
                "height": 600
            }
        }
    },
    "contributions": {
        "menu": [
            {
                "path": "i18n:menu.panel/gcore-framework",
                "label": "i18n:gcore-framework.open_panel",
                "message": "open-panel"
            },
            {
                "path": "i18n:menu.develop/gcore-framework",
                "label": "i18n:gcore-framework.send_to_panel",
                "message": "send-to-panel"
            }
        ],
        "messages": {
            "open-panel": {
                "methods": [
                    "openPanel"
                ]
            },
            "send-to-panel": {
                "methods": [
                    "default.hello"
                ]
            }
        },
        "asset-db": {
            "mount": {
                "path": "./assets",
                "readonly": false
            }
        }
    },
    "files": [
        "assets/scripts"
    ]
}