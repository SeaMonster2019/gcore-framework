{
    "include": [
        "../@types/cc/*.d.ts",
        "./**/*" // ← 必须同时加上这个！
    ],
    "compilerOptions": {
        "target": "es2022",
        "module": "es6",
        //"inlineSourceMap": true,
        "allowSyntheticDefaultImports": true,
        "sourceMap": true,
        "inlineSources": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": true,
        "experimentalDecorators": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,


        "rootDir": "./",
        "outDir": "../temp/",
        "paths": {
            "@msgpack/*": ["../../node_modules/@msgpack/*"],
            "@*": ["../../node_modules/@*"]
        },
        "types": [
            "node"
        ]
    }
}