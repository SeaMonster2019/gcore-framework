{
    "compilerOptions": {
        "target": "es2022",
        "module": "es6",
        //"inlineSourceMap": true,
        "allowSyntheticDefaultImports": true,
        "sourceMap": true,
        "inlineSources": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": true,
        "experimentalDecorators": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "rootDir": "./",
        "paths": {
            "@msgpack/*": [
                "../../node_modules/@msgpack/*"
            ],
            "gcore": [
                "./scripts/index.ts"
            ],
            "gcore/*": [
                "./scripts/*"
            ],
            "@gcore/event": [
                "./scripts/event/index.ts"
            ],
            "@gcore/storage": [
                "./scripts/storage/index.ts"
            ],
            "@gcore/utils": [
                "./scripts/utils/index.ts"
            ],
            "@gcore/res": [
                "./scripts/res/index.ts"
            ],
            "@gcore/mvc": [
                "./scripts/mvc/index.ts"
            ],
            "@gcore/ui": [
                "./scripts/ui/index.ts"
            ]
        },
        "types": [
            "../../../temp/declarations/cc.custom-macro",
            "../../../temp/declarations/cc",
            "../../../temp/declarations/jsb",
            "../../../temp/declarations/cc.env",
        ],
    },
    "exclude": [
        "node_modules",
        "../node_modules"
    ]
}